{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/favicon.(ico|png)",
      "dest": "/favicon.ico"
    },
    {
      "src": "/(.*\\.(css|js|csv|json|ico|png|svg))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
